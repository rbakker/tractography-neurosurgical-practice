---
import BrainViz from "./BrainViz.astro";
---

<section class="relative overflow-hidden border-b border-slate-800 bg-gradient-to-b from-slate-950 via-slate-950 to-slate-900">
  <div class="max-w-6xl mx-auto px-4 py-24 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <p class="text-primary font-semibold mb-3">Neuroimaging · Tractography · Connectomics</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
        Mapping structural connectivity in the human brain
      </h1>
      <p class="text-slate-300 text-lg mb-6">
        A multi-center scientific project combining advanced diffusion MRI tractography, open-source tools,
        and reproducible workflows to understand the human connectome.
      </p>
      <div class="flex gap-4">
        <a href={`${import.meta.env.BASE_URL}/project`} class="px-5 py-2.5 rounded-lg bg-primary hover:bg-primary-dark text-sm font-medium">
          Explore the project
        </a>
        <a href={`${import.meta.env.BASE_URL}/publications`} class="px-5 py-2.5 rounded-lg border border-slate-700 text-sm font-medium hover:border-slate-500">
          View publications
        </a>
      </div>
    </div>
    <BrainViz />
  </div>
</section>
