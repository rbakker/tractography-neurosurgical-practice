---
const { title, slug, summary } = Astro.props;
---

<a href={`${import.meta.env.BASE_URL}/project/${slug}`} class="group block p-6 rounded-2xl border border-slate-800 bg-slate-900/40 hover:border-primary/70 hover:bg-slate-900 transition">
  <h3 class="text-xl font-semibold mb-2 group-hover:text-primary">{title}</h3>
  <p class="text-slate-300 text-sm">{summary}</p>
</a>
