---
const { id, title, subtitle } = Astro.props;
---

<section id={id} class="max-w-6xl mx-auto px-4 py-16">
  {title && (
    <header class="mb-8">
      <h2 class="text-3xl font-semibold tracking-tight">{title}</h2>
      {subtitle && <p class="text-slate-400 mt-2 max-w-2xl">{subtitle}</p>}
    </header>
  )}
  <div>
    <slot />
  </div>
</section>
