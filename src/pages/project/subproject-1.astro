---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
---

<BaseLayout title="Subproject 1: Acquisition">
  <Section
    title="Subproject 1: Acquisition"
    subtitle="Harmonized, high-quality diffusion MRI acquisition across multiple centers."
  >
    <p class="text-slate-300 mb-4">
      This subproject defines and implements standardized diffusion MRI protocols, ensuring comparable data quality across
      scanners and sites. It includes phantom calibration, motion correction strategies, and quality assurance procedures.
    </p>
    <p class="text-slate-300">
      You can expand this section with figures, protocol tables, and links to acquisition guidelines or SOPs.
    </p>
  </Section>
</BaseLayout>
